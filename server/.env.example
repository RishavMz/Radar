# Flask
FLASK_ENV=development          # development | production
FLASK_HOST=0.0.0.0
FLASK_PORT=5000

# Database
DATABASE_URL=sqlite:///radar.db   # or postgres://user:pass@host/db

# BLE scanner
BLE_DEFAULT_TX_POWER=-59       # Reference TX power (dBm) when not advertised by device
BLE_PATH_LOSS_N=2.0            # Path-loss exponent (2.0 = free space, 2-3 indoors)
BLE_SCAN_TIMEOUT=10.0          # Duration (seconds) of each individual BLE scan pass
BLE_SCAN_INTERVAL_SECONDS=15   # How often (seconds) the background scan job fires

# Data retention
BLE_RETENTION_SECONDS=120      # How long (seconds) scan records are kept
PURGE_INTERVAL_SECONDS=30      # How often the purge job runs (seconds)
